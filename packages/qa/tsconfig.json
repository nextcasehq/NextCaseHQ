{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*", "specs/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "specs/**/*",
    "**/spec/**",
    "**/test/**",
    "**/__tests__/**",
    "**/fixtures/**",
    "**/mocks/**",
    "**/storybook/**"
  ]
}
