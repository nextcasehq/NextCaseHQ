# PostgreSQL connection string used by apps/web/src/lib/db/db-client.ts and
# scripts/db/migrate.js. Required at runtime only (not at build time).
#
# Local development:
#   DATABASE_URL=postgres://nextcase:<password>@localhost:5432/nextcase_dev
#
# Supabase (staging/production): use the "Session pooler" or direct
# connection string from Project Settings -> Database -> Connection string.
#   DATABASE_URL=postgres://postgres.<project-ref>:<password>@<host>:5432/postgres
DATABASE_URL=
