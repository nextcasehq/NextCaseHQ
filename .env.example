# PostgreSQL connection string used by apps/web/src/lib/db/db-client.ts.
# Required at runtime only (not at build time).
#
# IMPORTANT: this must be the least-privilege `nextcase_app` role created by
# db/schema.sql (NOSUPERUSER, NOBYPASSRLS), never an admin/superuser role.
# Postgres superusers — and Supabase's default `postgres` role — always
# bypass Row Level Security, which would silently defeat tenant isolation.
#
# Local development (after running `pnpm db:migrate` with an admin
# connection string, then `ALTER ROLE nextcase_app WITH PASSWORD '...'`):
#   DATABASE_URL=postgres://nextcase_app:<password>@localhost:5432/nextcase_dev
#
# Supabase (staging/production): create a dedicated Postgres role via the
# SQL editor or a migration connection (see PR description for exact
# steps), then use its connection string here — not the project's default
# `postgres` role.
DATABASE_URL=

# Separate admin/migration connection string, used only for
# `pnpm db:migrate` (DDL: creates tables, the nextcase_app role, indexes,
# policies). Needs CREATEROLE + table-owner privileges; the Supabase
# default `postgres` role is appropriate here specifically because this is
# the one operation that legitimately needs elevated privileges.
#   MIGRATION_DATABASE_URL=postgres://postgres.<project-ref>:<password>@<host>:5432/postgres
MIGRATION_DATABASE_URL=

# Signing secret for session JWTs, shared between apps/web/middleware.ts and
# apps/web/src/lib/auth/jwt.ts — both must use the same value. Falls back to
# an insecure placeholder if unset, which is fine for local dev but MUST be
# set to a real random secret (e.g. `openssl rand -base64 32`) in any shared
# or production environment.
JWT_SECRET=

# Optional: used only by `pnpm db:seed:dev-user` to create/update a local
# login user. No default password — the script refuses to run without one,
# so nothing resembling a credential ever ends up committed.
#   DEV_SEED_USER_PASSWORD=<pick-your-own-local-password>
# DEV_SEED_USER_EMAIL and DEV_SEED_TENANT_ID are also optional; see
# scripts/db/seed-dev-user.js for their defaults.
DEV_SEED_USER_PASSWORD=

# Signing secret for inbound webhook requests (POST /api/webhooks), used by
# apps/web/src/lib/security/webhook-signature.ts. Senders must compute
# HMAC-SHA256(secret, `${timestamp}.${rawBody}`) and send it as
# `sha256=<hex>` in the x-nextcase-signature header, with the timestamp
# (unix seconds) in x-nextcase-timestamp. Falls back to an insecure
# placeholder if unset, which is fine for local dev but MUST be set to a
# real random secret (e.g. `openssl rand -base64 32`) in any shared or
# production environment, and shared out-of-band with whatever system
# sends webhooks to this app.
WEBHOOK_SIGNING_SECRET=
