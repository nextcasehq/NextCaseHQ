# PostgreSQL connection string used by apps/web/src/lib/db/db-client.ts.
# Required at runtime only (not at build time).
#
# IMPORTANT: this must be the least-privilege `nextcase_app` role created by
# db/schema.sql (NOSUPERUSER, NOBYPASSRLS), never an admin/superuser role.
# Postgres superusers — and Supabase's default `postgres` role — always
# bypass Row Level Security, which would silently defeat tenant isolation.
#
# Local development (after running `pnpm db:migrate` with an admin
# connection string, then `ALTER ROLE nextcase_app WITH PASSWORD '...'`):
#   DATABASE_URL=postgres://nextcase_app:<password>@localhost:5432/nextcase_dev
#
# Supabase (staging/production): create a dedicated Postgres role via the
# SQL editor or a migration connection (see PR description for exact
# steps), then use its connection string here — not the project's default
# `postgres` role.
DATABASE_URL=

# Separate admin/migration connection string, used only for
# `pnpm db:migrate` (DDL: creates tables, the nextcase_app role, indexes,
# policies). Needs CREATEROLE + table-owner privileges; the Supabase
# default `postgres` role is appropriate here specifically because this is
# the one operation that legitimately needs elevated privileges.
#   MIGRATION_DATABASE_URL=postgres://postgres.<project-ref>:<password>@<host>:5432/postgres
MIGRATION_DATABASE_URL=

# Signing secret for session JWTs, shared between apps/web/middleware.ts and
# apps/web/src/lib/auth/jwt.ts — both must use the same value. Falls back to
# an insecure placeholder if unset, which is fine for local dev but MUST be
# set to a real random secret (e.g. `openssl rand -base64 32`) in any shared
# or production environment.
JWT_SECRET=

# Optional: used only by `pnpm db:seed:dev-user` to create/update a local
# login user. No default password — the script refuses to run without one,
# so nothing resembling a credential ever ends up committed.
#   DEV_SEED_USER_PASSWORD=<pick-your-own-local-password>
# DEV_SEED_USER_EMAIL and DEV_SEED_TENANT_ID are also optional; see
# scripts/db/seed-dev-user.js for their defaults.
DEV_SEED_USER_PASSWORD=

# Signing secret for inbound webhook requests (POST /api/webhooks), used by
# apps/web/src/lib/security/webhook-signature.ts. Senders must compute
# HMAC-SHA256(secret, `${timestamp}.${rawBody}`) and send it as
# `sha256=<hex>` in the x-nextcase-signature header, with the timestamp
# (unix seconds) in x-nextcase-timestamp. Falls back to an insecure
# placeholder if unset, which is fine for local dev but MUST be set to a
# real random secret (e.g. `openssl rand -base64 32`) in any shared or
# production environment, and shared out-of-band with whatever system
# sends webhooks to this app.
WEBHOOK_SIGNING_SECRET=

# Admin console secret key, verified server-side by
# POST /api/admin/session (apps/web/src/app/api/admin/session/route.ts) —
# the real "Platform Operator Secret Key" the admin login form's key is
# checked against. Falls back to an insecure placeholder if unset, which is
# fine for local dev but MUST be set to a real random secret in any shared
# or production environment.
ADMIN_ACCESS_TOKEN=

# Signing secret for the admin console's own session JWT, minted by
# POST /api/admin/session once ADMIN_ACCESS_TOKEN has been verified, and
# checked by apps/web/middleware.ts for every other /api/admin/* route —
# see apps/web/src/lib/security/admin-session.ts. Deliberately separate
# from JWT_SECRET (regular user sessions), so the two trust boundaries
# don't share a signing key. Falls back to an insecure placeholder if
# unset, which is fine for local dev but MUST be set to a real random
# secret (e.g. `openssl rand -base64 32`) in any shared or production
# environment.
ADMIN_SESSION_SECRET=

# Redis connection string, used by apps/web/src/lib/security/redis-client.ts
# to make login (POST /api/auth/session) and admin-login
# (POST /api/admin/session) rate limiting shared across every instance of
# the app, rather than each instance enforcing its own separate limit.
# Falls back to a per-process in-memory limiter if unset, which is fine
# for local dev and a single-instance deployment, but MUST be set to a
# real Redis instance (e.g. Upstash, ElastiCache, or self-hosted) in any
# horizontally-scaled production environment.
#   REDIS_URL=redis://default:<password>@<host>:6379
#
# Note: POST /api/webhooks runs on the Edge runtime and is NOT covered by
# this variable — ioredis needs Node's net/tls modules, which don't exist
# on Edge. Its rate limit and replay guard (lib/security/rate-limit.ts,
# lib/security/replay-guard.ts) remain in-memory/per-instance pending a
# Product Owner decision on an Edge-compatible approach (see
# docs/PENDING_INTEGRATION_REGISTER.md).
REDIS_URL=

# Object storage for document file bytes (POST /api/documents/upload,
# GET /api/documents/[id]/download), used by
# apps/web/src/lib/storage/object-storage.ts — a plain @aws-sdk/client-s3
# client, so ANY S3-API-compatible endpoint works here: real AWS S3,
# Supabase Storage's S3-compatible endpoint, MinIO, Cloudflare R2,
# DigitalOcean Spaces, or (for local dev/test) s3rver — nothing in this
# app is tied to one vendor. Required for uploads to succeed at all; MUST
# be set in production (enforced by env-validation.ts).
#
# Local development / running the test suite (no account needed):
#   pnpm test:start-s3rver   (starts a real local S3-compatible server)
#   S3_ENDPOINT=http://127.0.0.1:4569
#   S3_BUCKET=nextcase-documents-test
#   S3_ACCESS_KEY_ID=S3RVER
#   S3_SECRET_ACCESS_KEY=S3RVER
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Defaults to us-east-1 if unset — most self-hosted S3-compatible services
# ignore region entirely, but the field is required by the S3 API shape.
S3_REGION=
# Defaults to true (path-style: http://host/bucket/key), which is what
# MinIO, s3rver, and most self-hosted S3-compatible services expect. Set
# to "false" only for a provider that specifically requires
# virtual-hosted-style addressing.
S3_FORCE_PATH_STYLE=

# Comma-separated list of origins trusted for CSRF (Origin/Referer)
# verification on state-changing routes — see
# apps/web/src/lib/security/origin-check.ts. Defaults to
# http://localhost:3000 if unset. Set to your real app URL(s) in any
# shared or production environment, e.g.:
#   ALLOWED_ORIGINS=https://app.nextcase.in
ALLOWED_ORIGINS=
