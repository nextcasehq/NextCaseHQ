{
  "repository": "NextCaseHQ",
  "appPath": "apps/web/src/app",
  "componentsPath": "apps/web/src/components",
  "packagesPath": "packages",
  "forbiddenPatterns": [
    "javascript:void(0)",
    "href=\"#\""
  ],
  "constitutionalRules": {
    "rlsGuard": "SET LOCAL nextcase.current_tenant_id",
    "piiRegexes": [
      "[A-Z]{5}[0-9]{4}[A-Z]{1}",
      "[2-9]{1}[0-9]{3}\\s[0-9]{4}\\s[0-9]{4}"
    ]
  }
}
